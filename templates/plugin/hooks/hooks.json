{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -n \"${CLAUDE_PLUGIN_ROOT:-}\" && echo 'CCG plugin root: '\"$CLAUDE_PLUGIN_ROOT\" || echo 'WARNING: CLAUDE_PLUGIN_ROOT not set'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/manage-pre-task.sh\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|TaskOutput",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/manage-post-task.sh\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/manage-check-complete.sh\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
