{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -n \"${CLAUDE_PLUGIN_ROOT:-}\" && echo 'CCG plugin root: '\"$CLAUDE_PLUGIN_ROOT\" || echo 'WARNING: CLAUDE_PLUGIN_ROOT not set'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/manage-context-anchor.sh\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Task|TaskCreate|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/manage-pre-task.sh\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/manage-validate-agent.sh\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|TaskOutput|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/manage-post-task.sh\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/scripts/manage-check-complete.sh\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
